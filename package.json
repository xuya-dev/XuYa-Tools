{
  "name": "xuya-tools",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:rust": "cargo test --manifest-path src-tauri/Cargo.toml",
    "typecheck": "vue-tsc -b --noEmit",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,vue,css,html,json}\" \"*.{ts,js,json,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,vue,css,html,json}\" \"*.{ts,js,json,md}\"",
    "fmt:rust": "cargo fmt --manifest-path src-tauri/Cargo.toml",
    "clippy": "cargo clippy --manifest-path src-tauri/Cargo.toml -- -D warnings",
    "version": "node scripts/bump-version.cjs"
  },
  "dependencies": {
    "@lobehub/icons-static-svg": "^1.91.0",
    "@lucide/vue": "^1.21.0",
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-autostart": "^2.5.1",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "@types/crypto-js": "^4.2.2",
    "@types/js-yaml": "^4.0.9",
    "crypto-js": "^4.2.0",
    "highlight.js": "^11.11.1",
    "html-to-image": "^1.11.13",
    "js-md5": "^0.8.3",
    "js-yaml": "^5.2.0",
    "marked": "^18.0.5",
    "marked-highlight": "^2.2.4",
    "sm-crypto": "^0.4.0",
    "sql-formatter": "^15.8.2",
    "vue": "^3.5.25",
    "vue-router": "^4.6.4",
    "xml-js": "^1.6.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tauri-apps/cli": "^2.11.3",
    "@types/node": "^24.10.1",
    "@types/qrcode": "^1.5.6",
    "@vitejs/plugin-vue": "^6.0.2",
    "@vitest/coverage-v8": "^3.2.6",
    "@vue/test-utils": "^2.4.11",
    "@vue/tsconfig": "^0.8.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-vue": "^9.33.0",
    "happy-dom": "^18.0.1",
    "jsqr": "^1.4.0",
    "prettier": "^3.9.1",
    "qrcode": "^1.5.4",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.0",
    "vitest": "^3.2.6",
    "vue-eslint-parser": "^9.4.3",
    "vue-tsc": "^3.1.5"
  }
}
