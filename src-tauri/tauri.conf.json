{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "XuYa Tools",
  "version": "0.1.0",
  "identifier": "dev.xuya.tools",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "XuYa Tools",
        "width": 1100,
        "height": 720,
        "minWidth": 820,
        "minHeight": 560,
        "resizable": true,
        "decorations": false,
        "center": true,
        "maximizable": true,
        "minimizable": true,
        "url": "index.html",
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
